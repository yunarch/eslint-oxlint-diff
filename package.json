{
  "$schema": "https://json.schemastore.org/package",
  "name": "@yunarch/eslint-oxlint-diff",
  "version": "0.2.0",
  "description": "CLI tool to compare ESLint and OxLint rules, showing coverage gaps and overlap.",
  "license": "MIT",
  "keywords": [
    "eslint",
    "oxlint",
    "diff"
  ],
  "author": {
    "name": "Adrian Lopez Gonzalez",
    "url": "https://github.com/yunarch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yunarch/eslint-oxlint-diff.git"
  },
  "bugs": {
    "url": "https://github.com/yunarch/eslint-oxlint-diff/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "README.md",
    "LICENSE.md",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "@yunarch/eslint-oxlint-diff": "dist/cli.mjs"
  },
  "exports": {
    "types": "./dist/index.d.mts",
    "import": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky && bun run gen",
    "gen": "bun run --parallel gen:docs gen:oxc",
    "gen:docs": "bun run ./scripts/docsgen.ts",
    "gen:oxc": "bun run ./scripts/oxcgen.ts && oxfmt format --write ./.oxlintrc.json ./.oxfmtrc.json",
    "lint": "bun run --parallel lint:code lint:ts",
    "lint:code": "oxlint --type-aware",
    "lint:ts": "tsc --noEmit",
    "format": "oxfmt format --check ./",
    "format:all": "oxfmt format --write ./",
    "clean": "rimraf dist",
    "build": "tsdown",
    "tests": "bun test",
    "tests:watch": "bun test --watch",
    "tests:dist": "bun run build && TEST_DIST=true bun test",
    "release": "bun run lint && bun run tests:dist && HUSKY=0 bunx bumpp"
  },
  "dependencies": {
    "commander": "14.0.3",
    "jsonc-parser": "3.3.1",
    "@oxlint/migrate": "1.51.0"
  },
  "devDependencies": {
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.16.0",
    "husky": "9.1.7",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "tsdown": "0.21.1",
    "@types/node": "25.4.0",
    "@types/bun": "1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
